{
  "name": "unisex-fashion-store",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/prepare-db.mjs && prisma generate && next dev",
    "build": "node scripts/prepare-db.mjs && prisma generate && next build",
    "vercel-build": "node scripts/vercel-build.mjs",
    "start": "next start",
    "lint": "next lint",
    "db:prepare": "node scripts/prepare-db.mjs",
    "db:generate": "node scripts/prepare-db.mjs && prisma generate",
    "db:push": "node scripts/prepare-db.mjs && prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "node scripts/prepare-db.mjs && prisma db push && tsx prisma/seed.ts",
    "postinstall": "node scripts/prepare-db.mjs && prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.460.0",
    "next": "^14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
